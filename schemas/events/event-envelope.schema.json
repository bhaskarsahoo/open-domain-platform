{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-domain-platform.dev/schemas/events/event-envelope.schema.json",
  "title": "Open Domain Platform Event Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "source",
    "tenant_id",
    "occurred_at",
    "subject",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "minLength": 3,
      "examples": ["HarvestBatchCreated"]
    },
    "event_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "source": {
      "type": "string",
      "minLength": 3,
      "examples": ["erpnext.smart_farming"]
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "causation_id": {
      "type": "string",
      "format": "uuid"
    },
    "actor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": true,
      "required": ["doctype", "name"],
      "properties": {
        "doctype": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
