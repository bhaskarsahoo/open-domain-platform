{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-domain-platform.dev/schemas/module-manifest/module-manifest.schema.json",
  "title": "Open Domain Platform Module Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "module_id",
    "name",
    "version",
    "module_type",
    "status"
  ],
  "properties": {
    "module_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "module_type": {
      "type": "string",
      "enum": ["core", "domain", "capability", "integration", "workflow-pack"]
    },
    "status": {
      "type": "string",
      "enum": ["experimental", "active", "deprecated", "retired"]
    },
    "owns_doctypes": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "consumes_events": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "emits_events": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provides": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "calls": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "required_dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "optional_dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "required_permissions": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "configuration": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "required"],
        "properties": {
          "key": { "type": "string" },
          "required": { "type": "boolean" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
